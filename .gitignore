# ─── Almacenamiento de la bóveda (archivos cifrados de usuarios) ─────────────
/storage/vault/*
!/storage/vault/.gitkeep
/public/uploads/*
!/public/uploads/.gitkeep

# ─── Prisma ───────────────────────────────────────────────────────────────────
# El cliente se regenera con `prisma generate`; no se versiona.
/prisma/generated
*.db
*.db-journal

# ─── Pruebas / cobertura ──────────────────────────────────────────────────────
/coverage
/.vitest

# ─── Documentación técnica autogenerada (se regenera con `npm run docs`) ──────
/docs-site

